<mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- 标题 -->
    <mxCell id="title" value="客户端请求处理流程" style="text;fontSize:18;fontWeight:bold;fillColor=none;strokeColor=none;fontColor=#0044bb" vertex="1" parent="1">
      <mxGeometry x="420" y="20" width="240" height="30" as="geometry"/>
    </mxCell>
    <!-- 步骤1：接收报文 浅蓝框 -->
    <mxCell id="c1" value="接收客户端DNS查询报文" style="rounded=1;fillColor=#b3e0ff;strokeColor=#0066cc;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="380" y="70" width="320" height="50" as="geometry"/>
    </mxCell>
    <!-- 步骤2：解析报文 浅绿框 -->
    <mxCell id="c2" value="解析DNS报文&lt;br&gt;string_to_dnsstruct()" style="rounded=1;fillColor=#d9f2d9;strokeColor=#339933;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="380" y="140" width="320" height="60" as="geometry"/>
    </mxCell>
    <!-- 判断1：A记录查询？ 橙色菱形 -->
    <mxCell id="d1" value="A记录查询?" style="rhombus;fillColor=#ffddb3;strokeColor=#ff8800;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="430" y="220" width="220" height="70" as="geometry"/>
    </mxCell>
    <!-- A记录分支：查询LRU缓存 浅青框 -->
    <mxCell id="c3" value="查询LRU缓存" style="rounded=1;fillColor=#b3f0f8;strokeColor=#0099bb;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="180" y="320" width="200" height="50" as="geometry"/>
    </mxCell>
    <!-- 判断2：缓存命中？ 浅绿菱形 -->
    <mxCell id="d2" value="缓存命中?" style="rhombus;fillColor=#b8e4c9;strokeColor=#2d884d;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="210" y="390" width="140" height="60" as="geometry"/>
    </mxCell>
    <!-- 未命中分支：查询本地Trie树 浅黄框 -->
    <mxCell id="c4" value="查询本地Trie树&lt;br&gt;(dnsrelay.txt)" style="rounded=1;fillColor=#fff2b3;strokeColor=#e6b800;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="400" y="320" width="200" height="50" as="geometry"/>
    </mxCell>
    <!-- 判断3：本地命中？ 浅橙菱形 -->
    <mxCell id="d3" value="本地命中?" style="rhombus;fillColor=#ffdfc4;strokeColor=#f27c22;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="430" y="390" width="140" height="60" as="geometry"/>
    </mxCell>
    <!-- 非A记录直接转发标注 -->
    <mxCell id="note1" value="否(非A记录直接转发)" style="text;fontSize:11;fillColor=none;strokeColor=none;fontColor=#cc2222" vertex="1" parent="1">
      <mxGeometry x="650" y="250" width="130" height="20" as="geometry"/>
    </mxCell>
    <!-- 分配新ID 浅红框 -->
    <mxCell id="c5" value="分配新ID&lt;br&gt;reset_id()" style="rounded=1;fillColor=#f8c8d8;strokeColor=#d94873;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="390" y="480" width="220" height="55" as="geometry"/>
    </mxCell>
    <!-- 保存查询报文 浅红框 -->
    <mxCell id="c6" value="保存查询报文&lt;br&gt;save_query()" style="rounded=1;fillColor=#f8c8d8;strokeColor=#d94873;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="390" y="560" width="220" height="55" as="geometry"/>
    </mxCell>
    <!-- 构造应答报文 浅绿框 -->
    <mxCell id="c7" value="构造DNS应答报文&lt;br&gt;dnsstruct_to_string()" style="rounded=1;fillColor=#d9f2d9;strokeColor=#339933;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="650" y="320" width="220" height="60" as="geometry"/>
    </mxCell>
    <!-- 发送应答 浅蓝框 -->
    <mxCell id="c8" value="发送应答给客户端" style="rounded=1;fillColor=#b3e0ff;strokeColor=#0066cc;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="650" y="400" width="220" height="50" as="geometry"/>
    </mxCell>
    <!-- 写入日志 浅紫框 -->
    <mxCell id="c9" value="写入日志" style="rounded=1;fillColor=#e8d9f8;strokeColor=#9966cc;fontSize:12" vertex="1" parent="1">
      <mxGeometry x="670" y="470" width="180" height="50" as="geometry"/>
    </mxCell>
    <!-- 连接线：主流程纵向 -->
    <mxCell id="e1" edge="1" parent="1" source="c1" target="c2"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="c2" target="d1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <!-- A记录是→缓存分支 -->
    <mxCell id="e3" edge="1" parent="1" source="d1" target="c3"><mxGeometry relative="1" as="geometry"><mxPoint x="430" y="255"/><mxPoint x="280" y="320"/></mxGeometry></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="c3" target="d2"><mxGeometry relative="1" as="geometry"/></mxCell>
    <!-- 缓存命中→构造应答 -->
    <mxCell id="e5" edge="1" parent="1" source="d2" target="c7"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="355"/><mxPoint x="650" y="350"/></mxGeometry></mxCell>
    <!-- 缓存未命中→本地Trie树 -->
    <mxCell id="e6" edge="1" parent="1" source="d2" target="c4"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="420"/><mxPoint x="490" y="370"/></mxGeometry></mxCell>
    <mxCell id="e7" edge="1" parent="1" source="c4" target="d3"><mxGeometry relative="1" as="geometry"/></mxCell>
    <!-- 本地命中→构造应答 -->
    <mxCell id="e8" edge="1" parent="1" source="d3" target="c7"><mxGeometry relative="1" as="geometry"><mxPoint x="500" y="420"/><mxPoint x="650" y="350"/></mxGeometry></mxCell>
    <!-- 本地未命中→分配ID -->
    <mxCell id="e9" edge="1" parent="1" source="d3" target="c5"><mxGeometry relative="1" as="geometry"><mxPoint x="500" y="450"/><mxPoint x="500" y="480"/></mxGeometry></mxCell>
    <mxCell id="e10" edge="1" parent="1" source="c5" target="c6"><mxGeometry relative="1" as="geometry"/></mxCell>
    <!-- 非A记录直接转发→构造应答 -->
    <mxCell id="e11" edge="1" parent="1" source="d1" target="c7"><mxGeometry relative="1" as="geometry"><mxPoint x="540" y="255"/><mxPoint x="650" y="350"/></mxGeometry></mxCell>
    <!-- 应答后续流程 -->
    <mxCell id="e12" edge="1" parent="1" source="c7" target="c8"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e13" edge="1" parent="1" source="c8" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell>
  </root>
</mxGraphModel>
